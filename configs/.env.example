# Archivo de Entorno Semilla (Plantilla)
# ========================================================
# Este archivo define la estructura de variables esperadas 
# para despliegues del escáner en entornos de automatización.
# 
# [!] IMPORTANTE: No colocar contraseñas reales ni tokens aquí.
# Las credenciales de producción solo viven en el entorno final o bóveda segura.

# --- Configuración de Red Base ---
SCANNER_MAX_WORKERS=5000
SCANNER_DEFAULT_TIMEOUT=0.1
SCANNER_FALLBACK_DNS="8.8.8.8"

# --- Opciones de Reporte (Futuro uso) ---
# ENABLE_TELEGRAM_REPORTS=true
# TELEGRAM_BOT_TOKEN="AQUI_VA_EL_TOKEN_DEL_BOT"
# TELEGRAM_CHAT_ID="AQUI_VA_EL_CHAT_ID"

# --- Integración Base de Datos de Análisis Estocástico ---
# DB_HOST="localhost"
# DB_PORT=5432
# DB_USER="scanner_operator"
# DB_PASS="secret_password_here"
# DB_NAME="scan_metrics"

# --- Opciones DevSecOps / Debug ---
DEBUG_MODE=false
LOG_LEVEL="INFO"
FILE_LOGGING_PATH="/var/log/host-scan/scanner.log"
